# ============================================
# NetworkMemory AI Service - Environment Variables
# ============================================

# Copy this file to .env and fill in your actual values
# cp .env.example .env

# ============================================
# API Keys (Required)
# ============================================

# Google Gemini AI (for contact information extraction)
GEMINI_API_KEY=your_gemini_api_key_here

# AssemblyAI (for speaker diarization)
ASSEMBLYAI_API_KEY=your_assemblyai_api_key_here

# OpenAI (optional - for GPT-based features)
OPENAI_API_KEY=your_openai_api_key_here

# ElevenLabs (optional - for voice features)
ELEVENLABS_API_KEY=your_elevenlabs_api_key_here

# ============================================
# Backend Integration (NEW - For direct upload)
# ============================================

# Node.js Backend URL (where to send processed contacts)
BACKEND_URL=http://localhost:3000
# or for production: http://your-backend.vultr.com:3000

# ============================================
# Server Configuration
# ============================================

HOST=0.0.0.0
PORT=8000
DEBUG=True

# ============================================
# Audio Processing Settings
# ============================================

# Whisper model size: tiny, base, small, medium, large
# Smaller = faster but less accurate
# Larger = slower but more accurate
WHISPER_MODEL_SIZE=base

# Audio chunk length in seconds
CHUNK_LENGTH_SECONDS=90

# ============================================
# Service Selection
# ============================================

# Transcription: whisper (local, free) | assembly (cloud, paid)
TRANSCRIPTION_SERVICE=whisper

# Diarization: assembly (cloud, accurate, 5hrs free) | pyannote (local, free, good accuracy)
DIARIZATION_SERVICE=assembly

# Extraction: gemini (free tier) | gpt4 (paid) | claude (paid)
EXTRACTION_SERVICE=gemini

# ============================================
# Database (Optional - if using Supabase)
# ============================================

SUPABASE_URL=
SUPABASE_KEY=
