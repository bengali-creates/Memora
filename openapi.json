{
    "openapi": "3.1.0",
    "info": {
        "title": "NetworkMemory AI Service",
        "description": "AI service for processing conversations and extracting contact information",
        "version": "1.0.0"
    },
    "paths": {
        "/": {
            "get": {
                "summary": "Root",
                "description": "Root endpoint - API information\n\nUseful for:\n- Quick check that server is running\n- Finding other endpoints\n- API version info",
                "operationId": "root__get",
                "responses": {
                    "200": {
                        "description": "Successful Response",
                        "content": {
                            "application/json": {
                                "schema": {}
                            }
                        }
                    }
                }
            }
        },
        "/health": {
            "get": {
                "summary": "Health Check",
                "description": "Health check endpoint\n\nUsed by:\n- Load balancers\n- Monitoring systems (UptimeRobot, etc.)\n- Person 3's infrastructure checks\n\nReturns:\n- 200 OK if healthy\n- 503 Service Unavailable if unhealthy (e.g., pipeline not loaded)",
                "operationId": "health_check_health_get",
                "responses": {
                    "200": {
                        "description": "Successful Response",
                        "content": {
                            "application/json": {
                                "schema": {
                                    "$ref": "#/components/schemas/HealthResponse"
                                }
                            }
                        }
                    }
                }
            }
        },
        "/api/audio/process": {
            "post": {
                "summary": "Process Audio",
                "description": "Process audio file and extract contact information\n\nThis is the MAIN endpoint that Node.js calls\n\nFlow:\n1. Node.js uploads audio to Supabase Storage\n2. Node.js calls this endpoint with audio URL\n3. We download, process, and extract contact info\n4. Return contact card to Node.js\n5. Node.js stores in database and notifies frontend\n\nRequest body:\n    {\n        \"audio_url\": \"https://storage.supabase.co/...\",\n        \"event_context\": {\n            \"event_name\": \"DevFest Kolkata\",\n            \"location\": \"Kolkata\",\n            \"timestamp\": \"2026-03-04T15:30:00Z\"\n        }\n    }\n\nResponse:\n    {\n        \"status\": \"success\",\n        \"contact_card\": { ... },\n        \"metadata\": { ... }\n    }\n\nError handling:\n- 400 Bad Request: Invalid input\n- 500 Internal Server Error: Processing failed\n- 503 Service Unavailable: Pipeline not ready",
                "operationId": "process_audio_api_audio_process_post",
                "requestBody": {
                    "content": {
                        "application/json": {
                            "schema": {
                                "$ref": "#/components/schemas/AudioProcessRequest"
                            }
                        }
                    },
                    "required": true
                },
                "responses": {
                    "200": {
                        "description": "Successful Response",
                        "content": {
                            "application/json": {
                                "schema": {
                                    "$ref": "#/components/schemas/AudioProcessResponse"
                                }
                            }
                        }
                    },
                    "422": {
                        "description": "Validation Error",
                        "content": {
                            "application/json": {
                                "schema": {
                                    "$ref": "#/components/schemas/HTTPValidationError"
                                }
                            }
                        }
                    }
                }
            }
        },
        "/api/pipeline/info": {
            "get": {
                "summary": "Get Pipeline Info",
                "description": "Get information about the pipeline configuration\n\nUseful for debugging and monitoring\n\nOnly available in debug mode",
                "operationId": "get_pipeline_info_api_pipeline_info_get",
                "responses": {
                    "200": {
                        "description": "Successful Response",
                        "content": {
                            "application/json": {
                                "schema": {}
                            }
                        }
                    }
                }
            }
        }
    },
    "components": {
        "schemas": {
            "AudioProcessRequest": {
                "properties": {
                    "audio_url": {
                        "type": "string",
                        "title": "Audio Url",
                        "description": "URL to audio file (must be accessible, formats: wav, mp3, m4a)"
                    },
                    "event_context": {
                        "anyOf": [
                            {
                                "$ref": "#/components/schemas/EventContext"
                            },
                            {
                                "type": "null"
                            }
                        ],
                        "description": "Optional context about the event"
                    }
                },
                "type": "object",
                "required": [
                    "audio_url"
                ],
                "title": "AudioProcessRequest",
                "description": "Request to process audio and extract contact information\n\nThis is what Node.js backend will send to us",
                "example": {
                    "audio_url": "https://storage.supabase.co/bucket/audio_123.wav",
                    "event_context": {
                        "event_name": "TechCrunch Disrupt 2026",
                        "location": "San Francisco",
                        "timestamp": "2026-03-04T15:30:00Z"
                    }
                }
            },
            "AudioProcessResponse": {
                "properties": {
                    "status": {
                        "type": "string",
                        "title": "Status",
                        "description": "'success' or 'error'"
                    },
                    "contact_card": {
                        "anyOf": [
                            {
                                "$ref": "#/components/schemas/ContactCard"
                            },
                            {
                                "type": "null"
                            }
                        ],
                        "description": "Extracted contact information"
                    },
                    "metadata": {
                        "anyOf": [
                            {
                                "$ref": "#/components/schemas/ProcessingMetadata"
                            },
                            {
                                "type": "null"
                            }
                        ],
                        "description": "Processing metadata"
                    },
                    "raw_data": {
                        "anyOf": [
                            {
                                "$ref": "#/components/schemas/RawData"
                            },
                            {
                                "type": "null"
                            }
                        ],
                        "description": "Raw processing data (debug only)"
                    },
                    "error": {
                        "anyOf": [
                            {
                                "type": "string"
                            },
                            {
                                "type": "null"
                            }
                        ],
                        "title": "Error",
                        "description": "Error message if processing failed"
                    }
                },
                "type": "object",
                "required": [
                    "status"
                ],
                "title": "AudioProcessResponse",
                "description": "Response from audio processing\n\nTwo possible states:\n1. Success: status=\"success\", contact_card present\n2. Error: status=\"error\", error message present",
                "example": {
                    "contact_card": {
                        "company": "Google",
                        "confidence_score": 0.87,
                        "name": "Sarah Chen",
                        "role": "ML Engineer"
                    },
                    "metadata": {
                        "audio_duration": 120.0,
                        "num_speakers": 2,
                        "processing_time": 18.5,
                        "utterances_count": 24
                    },
                    "status": "success"
                }
            },
            "ContactCard": {
                "properties": {
                    "name": {
                        "anyOf": [
                            {
                                "type": "string"
                            },
                            {
                                "type": "null"
                            }
                        ],
                        "title": "Name",
                        "description": "Person's full name"
                    },
                    "role": {
                        "anyOf": [
                            {
                                "type": "string"
                            },
                            {
                                "type": "null"
                            }
                        ],
                        "title": "Role",
                        "description": "Job title or role"
                    },
                    "company": {
                        "anyOf": [
                            {
                                "type": "string"
                            },
                            {
                                "type": "null"
                            }
                        ],
                        "title": "Company",
                        "description": "Company or organization"
                    },
                    "location": {
                        "anyOf": [
                            {
                                "type": "string"
                            },
                            {
                                "type": "null"
                            }
                        ],
                        "title": "Location",
                        "description": "City or region they're from"
                    },
                    "phone": {
                        "anyOf": [
                            {
                                "type": "string"
                            },
                            {
                                "type": "null"
                            }
                        ],
                        "title": "Phone",
                        "description": "Phone number if mentioned"
                    },
                    "email": {
                        "anyOf": [
                            {
                                "type": "string"
                            },
                            {
                                "type": "null"
                            }
                        ],
                        "title": "Email",
                        "description": "Email if mentioned"
                    },
                    "linkedin_url": {
                        "anyOf": [
                            {
                                "type": "string"
                            },
                            {
                                "type": "null"
                            }
                        ],
                        "title": "Linkedin Url",
                        "description": "LinkedIn URL if mentioned"
                    },
                    "topics_discussed": {
                        "items": {
                            "type": "string"
                        },
                        "type": "array",
                        "title": "Topics Discussed",
                        "description": "Array of topics discussed (e.g., ['AI safety', 'Startups'])"
                    },
                    "follow_ups": {
                        "items": {
                            "type": "string"
                        },
                        "type": "array",
                        "title": "Follow Ups",
                        "description": "Action items mentioned (e.g., ['Send GitHub repo', 'Connect on LinkedIn'])"
                    },
                    "conversation_summary": {
                        "type": "string",
                        "title": "Conversation Summary",
                        "description": "2-3 sentence summary of the conversation"
                    },
                    "confidence_score": {
                        "type": "number",
                        "maximum": 1.0,
                        "minimum": 0.0,
                        "title": "Confidence Score",
                        "description": "Confidence in extraction quality (0.0 to 1.0)"
                    },
                    "met_at": {
                        "anyOf": [
                            {
                                "type": "string"
                            },
                            {
                                "type": "null"
                            }
                        ],
                        "title": "Met At",
                        "description": "Event name where they met"
                    },
                    "met_date": {
                        "anyOf": [
                            {
                                "type": "string"
                            },
                            {
                                "type": "null"
                            }
                        ],
                        "title": "Met Date",
                        "description": "Date of meeting"
                    },
                    "met_location": {
                        "anyOf": [
                            {
                                "type": "string"
                            },
                            {
                                "type": "null"
                            }
                        ],
                        "title": "Met Location",
                        "description": "Location of meeting"
                    },
                    "raw_conversation": {
                        "anyOf": [
                            {
                                "type": "string"
                            },
                            {
                                "type": "null"
                            }
                        ],
                        "title": "Raw Conversation",
                        "description": "Full diarized conversation text"
                    },
                    "extraction_time": {
                        "anyOf": [
                            {
                                "type": "number"
                            },
                            {
                                "type": "null"
                            }
                        ],
                        "title": "Extraction Time",
                        "description": "Time taken to extract (seconds)"
                    }
                },
                "type": "object",
                "required": [
                    "conversation_summary",
                    "confidence_score"
                ],
                "title": "ContactCard",
                "description": "Extracted contact information\n\nWhy these fields:\n- name: Most important - who did you meet?\n- role/company: Context about the person\n- topics_discussed: What did you talk about? (for search)\n- follow_ups: Action items (for reminders)\n- confidence_score: How sure are we? (for UI indicators)",
                "example": {
                    "company": "Google",
                    "confidence_score": 0.87,
                    "conversation_summary": "Discussed AI safety work at Google focusing on LLM alignment and interpretability. Sarah offered to share research papers and mentioned hiring opportunities.",
                    "follow_ups": [
                        "Connect on LinkedIn",
                        "Send research papers"
                    ],
                    "location": "Mountain View",
                    "met_at": "DevFest Kolkata 2026",
                    "name": "Sarah Chen",
                    "role": "ML Engineer",
                    "topics_discussed": [
                        "AI safety",
                        "LLM alignment",
                        "Interpretability"
                    ]
                }
            },
            "EventContext": {
                "properties": {
                    "event_name": {
                        "anyOf": [
                            {
                                "type": "string"
                            },
                            {
                                "type": "null"
                            }
                        ],
                        "title": "Event Name",
                        "description": "Name of the event (e.g., 'DevFest Kolkata 2026')"
                    },
                    "location": {
                        "anyOf": [
                            {
                                "type": "string"
                            },
                            {
                                "type": "null"
                            }
                        ],
                        "title": "Location",
                        "description": "Location of the event (e.g., 'Kolkata, India')"
                    },
                    "timestamp": {
                        "anyOf": [
                            {
                                "type": "string"
                            },
                            {
                                "type": "null"
                            }
                        ],
                        "title": "Timestamp",
                        "description": "ISO 8601 timestamp of when conversation happened"
                    }
                },
                "type": "object",
                "title": "EventContext",
                "description": "Context about the event where conversation happened\n\nAll fields optional because:\n- Event detection might fail\n- User might not provide context\n- Better to process with partial info than fail",
                "example": {
                    "event_name": "DevFest Kolkata 2026",
                    "location": "Kolkata, India",
                    "timestamp": "2026-03-04T15:30:00Z"
                }
            },
            "HTTPValidationError": {
                "properties": {
                    "detail": {
                        "items": {
                            "$ref": "#/components/schemas/ValidationError"
                        },
                        "type": "array",
                        "title": "Detail"
                    }
                },
                "type": "object",
                "title": "HTTPValidationError"
            },
            "HealthResponse": {
                "properties": {
                    "status": {
                        "type": "string",
                        "title": "Status",
                        "description": "'healthy' or 'unhealthy'"
                    },
                    "message": {
                        "type": "string",
                        "title": "Message"
                    },
                    "version": {
                        "type": "string",
                        "title": "Version"
                    },
                    "timestamp": {
                        "type": "string",
                        "title": "Timestamp"
                    }
                },
                "type": "object",
                "required": [
                    "status",
                    "message",
                    "version"
                ],
                "title": "HealthResponse",
                "description": "Simple health check response",
                "example": {
                    "message": "NetworkMemory AI Service is running",
                    "status": "healthy",
                    "timestamp": "2026-03-04T12:00:00Z",
                    "version": "1.0.0"
                }
            },
            "ProcessingMetadata": {
                "properties": {
                    "audio_duration": {
                        "anyOf": [
                            {
                                "type": "number"
                            },
                            {
                                "type": "null"
                            }
                        ],
                        "title": "Audio Duration",
                        "description": "Duration of audio in seconds"
                    },
                    "num_speakers": {
                        "anyOf": [
                            {
                                "type": "integer"
                            },
                            {
                                "type": "null"
                            }
                        ],
                        "title": "Num Speakers",
                        "description": "Number of speakers detected"
                    },
                    "processing_time": {
                        "type": "number",
                        "title": "Processing Time",
                        "description": "Total processing time in seconds"
                    },
                    "utterances_count": {
                        "anyOf": [
                            {
                                "type": "integer"
                            },
                            {
                                "type": "null"
                            }
                        ],
                        "title": "Utterances Count",
                        "description": "Number of conversational turns"
                    }
                },
                "type": "object",
                "required": [
                    "processing_time"
                ],
                "title": "ProcessingMetadata",
                "description": "Metadata about the processing pipeline\n\nUseful for:\n- Performance monitoring\n- Debugging\n- Showing user \"what happened\"\n\nNote: Some fields are optional because they may not be available if processing fails early"
            },
            "RawData": {
                "properties": {
                    "full_transcription": {
                        "anyOf": [
                            {
                                "type": "string"
                            },
                            {
                                "type": "null"
                            }
                        ],
                        "title": "Full Transcription"
                    },
                    "diarized_conversation": {
                        "anyOf": [
                            {
                                "type": "string"
                            },
                            {
                                "type": "null"
                            }
                        ],
                        "title": "Diarized Conversation"
                    },
                    "utterances": {
                        "anyOf": [
                            {
                                "items": {
                                    "additionalProperties": true,
                                    "type": "object"
                                },
                                "type": "array"
                            },
                            {
                                "type": "null"
                            }
                        ],
                        "title": "Utterances"
                    }
                },
                "type": "object",
                "title": "RawData",
                "description": "Raw processing results for debugging\n\nOnly included if debug mode is on"
            },
            "ValidationError": {
                "properties": {
                    "loc": {
                        "items": {
                            "anyOf": [
                                {
                                    "type": "string"
                                },
                                {
                                    "type": "integer"
                                }
                            ]
                        },
                        "type": "array",
                        "title": "Location"
                    },
                    "msg": {
                        "type": "string",
                        "title": "Message"
                    },
                    "type": {
                        "type": "string",
                        "title": "Error Type"
                    }
                },
                "type": "object",
                "required": [
                    "loc",
                    "msg",
                    "type"
                ],
                "title": "ValidationError"
            }
        }
    }
}