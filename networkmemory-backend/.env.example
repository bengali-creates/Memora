# NetworkMemory Backend - Environment Variables

# ============================================
# DATABASE
# ============================================
DATABASE_URL=postgresql://user:password@host:5432/database

# ============================================
# AUTH0 - USER AUTHENTICATION
# ============================================
# Setup: Auth0 Dashboard → Applications → Create Application → Native
# Leave blank for development mode (uses mock authentication)
AUTH0_DOMAIN=your-domain.auth0.com
AUTH0_ISSUER_BASE_URL=https://your-domain.auth0.com
AUTH0_API_AUDIENCE=https://networkmemory-api

# ============================================
# AUTH0 - M2M AUTHENTICATION (Python AI)
# ============================================
# Setup: Auth0 Dashboard → Applications → Create Application → Machine to Machine
# Leave blank to call Python AI without authentication
AUTH0_M2M_CLIENT_ID=your-m2m-client-id
AUTH0_M2M_CLIENT_SECRET=your-m2m-client-secret
AUTH0_M2M_AUDIENCE=https://networkmemory-api

# ============================================
# PYTHON AI SERVICE
# ============================================
PYTHON_AI_URL=http://localhost:8000

# ============================================
# GEMINI API (for TalkBot & Semantic Search)
# ============================================
GEMINI_API_KEY=your-gemini-api-key

# ============================================
# SERVER CONFIG
# ============================================
PORT=3000
NODE_ENV=development
ALLOWED_ORIGINS=*
