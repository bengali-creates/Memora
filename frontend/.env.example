# NetworkMemory Frontend - Environment Variables Example

# ============================================
# AUTH0 CONFIGURATION
# ============================================
# Get these from: Auth0 Dashboard → Applications → NetworkMemory Mobile App

# Your Auth0 domain
EXPO_PUBLIC_AUTH0_DOMAIN=your-app.auth0.com

# Your Auth0 Client ID
EXPO_PUBLIC_AUTH0_CLIENT_ID=your-client-id-here

# Your API Audience
EXPO_PUBLIC_AUTH0_AUDIENCE=https://networkmemory-api

# ============================================
# BACKEND API
# ============================================
# Backend API URL
EXPO_PUBLIC_API_URL=http://localhost:3000/api
